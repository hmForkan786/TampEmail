APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_SUPPORTED_LOCALES=en,bn
APP_FAKER_LOCALE=en_US
APP_TIMEZONE=UTC

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
TEST_DB_CONNECTION=sqlite
RUN_RELATIONAL_TESTS=0
INBOUND_WEBHOOK_TIMESTAMP_SKEW_SECONDS=300
INBOUND_WEBHOOK_MAX_BODY_BYTES=10485760
INBOUND_WEBHOOK_RATE_LIMIT_PER_MINUTE=60
INBOUND_GENERIC_WEBHOOK_SECRET=
ATTACHMENT_SCANNER_BACKEND=disabled
ATTACHMENT_CLAMAV_HOST=127.0.0.1
ATTACHMENT_CLAMAV_PORT=3310
ATTACHMENT_SCAN_TIMEOUT_SECONDS=30
ATTACHMENT_SCAN_MAX_BYTES=26214400
ATTACHMENT_MAX_COUNT=20
ATTACHMENT_MAX_TOTAL_BYTES=52428800
ATTACHMENT_SCAN_MAX_ATTEMPTS=3
ATTACHMENT_SCANNER_ENDPOINT=
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=temail
DB_USERNAME=root
DB_PASSWORD=
DB_CHARSET=utf8mb4
DB_COLLATION=utf8mb4_unicode_ci

SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=false
SESSION_SAME_SITE=lax

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis
QUEUE_FAILED_DRIVER=database-uuids
QUEUE_DEFAULT=default
QUEUE_MAIL_INGESTION=mail-ingestion
QUEUE_MAIL_PARSING=mail-parsing
QUEUE_MAIL_STORAGE=mail-storage
QUEUE_ATTACHMENT_SCANNING=attachment-scanning
QUEUE_ABUSE_ANALYSIS=abuse-analysis
QUEUE_RETENTION=retention
QUEUE_NOTIFICATIONS=notifications
QUEUE_ANALYTICS=analytics
QUEUE_EXPORTS=exports

CACHE_STORE=redis
CACHE_PREFIX=temail_cache

# Operational/API logs: configurable contract; cleanup is implemented separately.
API_REQUEST_LOG_RETENTION_DAYS=30
AUDIT_LOG_RETENTION_DAYS=2555
AUDIT_LOG_RETENTION_CLEANUP_ENABLED=false
LOG_RETENTION_CLEANUP_SCHEDULE=daily
LOG_RETENTION_BATCH_SIZE=500

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_USERNAME=null
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_DB=1
REDIS_QUEUE_DB=2
REDIS_CACHE_CONNECTION=cache
REDIS_CACHE_LOCK_CONNECTION=default
REDIS_QUEUE_CONNECTION=queue
REDIS_QUEUE_RETRY_AFTER=120
REDIS_QUEUE_BLOCK_FOR=5

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_EHLO_DOMAIN=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_URL=
AWS_ENDPOINT=
AWS_USE_PATH_STYLE_ENDPOINT=false

FILESYSTEM_PRIVATE_DISK=local
FILESYSTEM_PUBLIC_DISK=public
FILESYSTEM_ATTACHMENTS_DISK=attachments
FILESYSTEM_MESSAGE_BODIES_DISK=message_bodies

LOG_SECURITY_CHANNEL=security
LOG_AUDIT_CHANNEL=audit
LOG_QUEUE_CHANNEL=queue
LOG_INGESTION_CHANNEL=ingestion

SECURITY_HEADERS_ENABLED=true
SECURITY_HSTS_ENABLED=false
SECURITY_HSTS_MAX_AGE=31536000
SECURITY_REFERRER_POLICY=strict-origin-when-cross-origin
SECURITY_PERMISSIONS_POLICY="camera=(), microphone=(), geolocation=()"

RATE_LIMIT_WEB_PER_MINUTE=120
RATE_LIMIT_API_PER_MINUTE=60
RATE_LIMIT_INBOX_CREATION_PER_HOUR=20
RATE_LIMIT_INGESTION_PER_MINUTE=300

# Inbox Configuration
INBOX_DEFAULT_TTL=86400
INBOX_PREMIUM_TTL=2592000
PUBLIC_INBOX_ENABLED=true
# Exact pool_key for anonymous/public inbox mail-server assignment. Leave empty to disable.
PUBLIC_MAIL_SERVER_POOL=
ALLOW_CUSTOM_ALIAS=false

# Message Configuration
MESSAGE_MAX_SIZE_MB=25
MESSAGE_HTML_SANITIZE=true

# Attachment Configuration
ATTACHMENT_MAX_SIZE_MB=20
ATTACHMENT_SCAN_ENABLED=true

# Inbound retention policy (cleanup disabled by default)
INBOUND_EMAIL_RETENTION_DAYS=30
INBOUND_BODY_RETENTION_DAYS=30
INBOUND_CLEAN_ATTACHMENT_RETENTION_DAYS=30
INBOUND_INFECTED_ATTACHMENT_RETENTION_DAYS=90
INBOUND_PENDING_ATTACHMENT_RETENTION_DAYS=7
INBOUND_FAILED_ATTACHMENT_RETENTION_DAYS=30
INBOUND_EVENT_RETENTION_DAYS=30
INBOUND_PROCESSING_LOG_RETENTION_DAYS=30
INBOUND_FAILURE_RETENTION_DAYS=90
INBOUND_RETENTION_BATCH_SIZE=500
INBOUND_RETENTION_SCHEDULE=daily
INBOUND_RETENTION_CLEANUP_ENABLED=false

# OTP Configuration
OTP_AUTO_DETECT=true

# Advertisement
ADS_ENABLED=true
ADS_PROVIDER=adsense
ADS_PREMIUM_HIDE=true

# Analytics
ANALYTICS_ENABLED=true

# API
API_VERSION=v1
API_RATE_LIMIT=60
API_KEY_HASH_SECRET=

# Feature Flags
FEATURE_PREMIUM=false
FEATURE_SEND_MAIL=false
FEATURE_REPLY=false
FEATURE_FORWARD=false
FEATURE_API=true
FEATURE_WEBHOOK=false
FEATURE_AI=false

VITE_APP_NAME="${APP_NAME}"
